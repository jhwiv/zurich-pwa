            // Helper function to add UTM parameters to outgoing URLs
            function addUtmParams(url, title) {
                if (!url) return url;
                const separator = url.includes('?') ? '&' : '?';
                const hostname = window.location.hostname;
                const domainParts = hostname.replace('www.', '').split('.');
                const siteName = domainParts[0].charAt(0).toUpperCase() + domainParts[0].slice(1);
                const utmParams = `utm_source=${encodeURIComponent(siteName)}&utm_medium=referral&utm_campaign=${encodeURIComponent('OpdagDanmark product feed')}&utm_content=${encodeURIComponent(title || '')}`;
                return `${url}${separator}${utmParams}`;
            }

