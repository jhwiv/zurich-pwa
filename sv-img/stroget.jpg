            const secondaryColor = '#e74c3c';
            const buttonTextColor = '#ffffff';

            function initSliderFilters() {
            let currentIndex = 0;
            let filteredProducts = [...ALL_PRODUCTS_DATA];

            // Auto-scroll state
            let autoScrollInterval = null;
            let userInteracted = false;
            let resumeTimeout = null;

            // Get elements (unique per instance)
            const uid = 'ps1';
            const sliderTrack = document.getElementById('productsSliderTrack_' + uid);
            const prevBtn = document.getElementById('productsSliderPrevBtn_' + uid);
            const nextBtn = document.getElementById('productsSliderNextBtn_' + uid);
            const searchInput = document.getElementById('productsSliderSearchInput_' + uid);
            const municipalitySelect = document.getElementById('productsSliderMunicipalitySelect_' + uid);
            const typeSelect = document.getElementById('productsSliderTypeSelect_' + uid);
            const sortSelect = document.getElementById('productsSliderSortSelect_' + uid);
            const sliderContainer = sliderTrack ? sliderTrack.closest('.products-slider-container') : null;

            // Detect number of visible cards based on viewport
            function getVisibleCards() {
                const width = window.innerWidth;
                if (width <= 480) return 1;
                if (width <= 1024) return 2;
                if (width <= 1400) return 3;
                return 4;
            }

            // Calculate card width including gap
            function getCardWidth() {
                const cards = sliderTrack.querySelectorAll('.product-card');
                if (cards.length === 0) return 0;

                const cardWidth = cards[0].offsetWidth;
                const gap = parseInt(window.getComputedStyle(sliderTrack).gap) || 30;

                return cardWidth + gap;
            }

            // Apply filters
            function applyFilters() {
                const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
                const selectedMunicipalities = municipalitySelect ? Array.from(municipalitySelect.selectedOptions).map(opt => opt.value) : [];
                const selectedType = typeSelect ? typeSelect.value : '';
                const sortBy = sortSelect ? sortSelect.value : '';

                filteredProducts = ALL_PRODUCTS_DATA.filter(product => {
                    // Search filter
                    if (searchTerm) {
                        const titleMatch = (product.title || '').toLowerCase().includes(searchTerm);
                        const descMatch = (product.shortDescription || '').toLowerCase().includes(searchTerm);
                        if (!titleMatch && !descMatch) return false;
                    }

                    // Municipality filter (by shopCity)
                    if (selectedMunicipalities.length > 0) {
                        const productCity = (product.shopCity || '').toLowerCase();
                        if (!selectedMunicipalities.includes(productCity)) return false;
                    }

                    // Category filter
                    if (selectedType) {
                        const productCats = (product.category || '').split(',').map(c => c.trim());
                        if (!productCats.includes(selectedType)) return false;
                    }

                    return true;
                });

                // Apply sorting
                if (sortBy === 'low') {
                    filteredProducts.sort((a, b) => a.currentPrice - b.currentPrice);
                } else if (sortBy === 'high') {
                    filteredProducts.sort((a, b) => b.currentPrice - a.currentPrice);
                } else if (sortBy === 'sale') {
                    filteredProducts.sort((a, b) => {
                        const aOnSale = a.salePrice > 0 ? 1 : 0;
                        const bOnSale = b.salePrice > 0 ? 1 : 0;
                        return bOnSale - aOnSale;
                    });
                }

                currentIndex = 0;
                renderProducts();
                updateButtons();
            }

            // Render products
            function renderProducts() {
                if (filteredProducts.length === 0) {
                    sliderTrack.innerHTML = `
                        <div class="no-products-msg-slider">
                            <div class="no-products-icon-slider">🔍</div>
                            <h3>Ingen produkter fundet</h3>
                            <p>Prøv at justere dine filtre</p>
                        </div>
                    `;
                    return;
                }

                sliderTrack.innerHTML = filteredProducts.map(product => {
                    const price = product.salePrice > 0 ? product.salePrice : product.price;
                    const hasDiscount = product.salePrice > 0;

                    return `
                        <div class="product-card event-card" data-product-id="${product.id}">
                            <div class="event-card-image" style="background-image: url('${product.image}'); background-size: cover; background-position: center; height: 220px;">
                                <div class="event-date-badge product-price-badge">
                                    ${hasDiscount ? `<span style="text-decoration: line-through; font-size: 12px; color: #999; display: block; margin-bottom: 2px;">${product.price} kr.</span>` : ''}
                                    <span style="color: ${hasDiscount ? '#e74c3c' : '#2c3e50'}; font-weight: 800;">${price} kr.</span>
                                </div>
                            </div>
                            <div class="event-card-body">
                                <h3 class="event-card-title">${product.title}</h3>
                                <p class="event-card-location">📍 ${product.shopName}, ${product.shopCity}</p>
                                <p class="event-card-desc">${product.shortDescription || ''}</p>
                                <div class="event-card-actions">
                                    <a href="${addUtmParams(product.url, product.title || 'Produkt')}" target="_blank" class="event-btn btn-ticket" style="background: ${secondaryColor} !important; color: ${buttonTextColor} !important;">
                                        ${product.buttonText || 'Læs mere'}
                                    </a>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            // Navigation
            function slideNext() {
                const visibleCards = getVisibleCards();
                if (currentIndex < filteredProducts.length - visibleCards) {
                    currentIndex++;
                    updateSliderPosition();
                    updateButtons();
                }
            }

            function slidePrev() {
                if (currentIndex > 0) {
                    currentIndex--;
                    updateSliderPosition();
                    updateButtons();
                }
            }

            function updateSliderPosition() {
                const cardWidth = getCardWidth();
                sliderTrack.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
            }

            function updateButtons() {
                const visibleCards = getVisibleCards();
                prevBtn.disabled = currentIndex === 0;
                nextBtn.disabled = currentIndex >= filteredProducts.length - visibleCards || filteredProducts.length === 0;
            }

            // Auto-scroll
            function startAutoScroll() {
                if (autoScrollInterval || filteredProducts.length === 0) return;

                autoScrollInterval = setInterval(() => {
                    const visibleCards = getVisibleCards();
                    if (currentIndex >= filteredProducts.length - visibleCards) {
                        currentIndex = 0;
                    } else {
                        currentIndex++;
                    }
                    updateSliderPosition();
                    updateButtons();
                }, 4000);
            }

            function stopAutoScroll() {
                if (autoScrollInterval) {
                    clearInterval(autoScrollInterval);
                    autoScrollInterval = null;
                }
            }

            // Pause auto-scroll on user interaction
            const pauseAutoScroll = () => {
                userInteracted = true;
                stopAutoScroll();

                if (resumeTimeout) {
                    clearTimeout(resumeTimeout);
                }

                resumeTimeout = setTimeout(() => {
                    userInteracted = false;
                    startAutoScroll();
                }, 5000);
            };

            // Event listeners
            prevBtn.addEventListener('click', () => {
                pauseAutoScroll();
                slidePrev();
            });

            nextBtn.addEventListener('click', () => {
                pauseAutoScroll();
                slideNext();
            });

            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }
            if (municipalitySelect) {
                municipalitySelect.addEventListener('change', applyFilters);
            }
            if (typeSelect) {
                typeSelect.addEventListener('change', applyFilters);
            }
            if (sortSelect) {
                sortSelect.addEventListener('change', applyFilters);
            }

            // Swipe and Drag functionality
            let isDragging = false;
            let startX = 0;
            let currentX = 0;
            let startTransform = 0;
            let startTime = 0;
            let velocity = 0;
            let hasMoved = false;

            // Touch events for swipe
            sliderContainer.addEventListener('touchstart', (e) => {
                pauseAutoScroll();
                isDragging = true;
                startX = e.touches[0].clientX;
                startTime = Date.now();
                const transform = sliderTrack.style.transform;
                startTransform = transform ? parseFloat(transform.replace('translateX(', '').replace('px)', '')) : 0;
                sliderTrack.style.transition = 'none';
                hasMoved = false;
                // Don't prevent default initially - let clicks through
            }, { passive: false });

            sliderContainer.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const moveX = e.touches[0].clientX;
                const diff = Math.abs(moveX - startX);

                // Only prevent default and move if user has moved more than 10px
                if (diff > 10) {
                    hasMoved = true;
                    e.preventDefault();
                    currentX = moveX;
                    const translateDiff = currentX - startX;
                    const newTransform = startTransform + translateDiff;
                    sliderTrack.style.transform = `translateX(${newTransform}px)`;
                }
            }, { passive: false });

            sliderContainer.addEventListener('touchend', (e) => {
                if (!isDragging) return;
                isDragging = false;

                const endTime = Date.now();
                const timeDiff = endTime - startTime;
                const distance = currentX - startX;
                velocity = Math.abs(distance / timeDiff);

                sliderTrack.style.transition = 'transform 0.5s ease';

                // Determine if we should move to next/prev slide
                const visibleCards = getVisibleCards();
                const maxIndex = filteredProducts.length - visibleCards;

                if (Math.abs(distance) > 50 || velocity > 0.3) {
                    if (distance > 0 && currentIndex > 0) {
                        currentIndex--;
                    } else if (distance < 0 && currentIndex < maxIndex) {
                        currentIndex++;
                    }
                }

                updateSliderPosition();
                updateButtons();
                startAutoScroll();
            });

            // Mouse events for drag
            sliderContainer.addEventListener('mousedown', (e) => {
                pauseAutoScroll();
                isDragging = true;
                startX = e.clientX;
                startTime = Date.now();
                const transform = sliderTrack.style.transform;
                startTransform = transform ? parseFloat(transform.replace('translateX(', '').replace('px)', '')) : 0;
                sliderTrack.style.transition = 'none';
                sliderContainer.style.cursor = 'grabbing';
                e.preventDefault();
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                currentX = e.clientX;
                const diff = currentX - startX;
                const newTransform = startTransform + diff;
                sliderTrack.style.transform = `translateX(${newTransform}px)`;
            });

            window.addEventListener('mouseup', (e) => {
                if (!isDragging) return;
                isDragging = false;
                sliderContainer.style.cursor = 'grab';

                const endTime = Date.now();
                const timeDiff = endTime - startTime;
                const distance = currentX - startX;
                velocity = Math.abs(distance / timeDiff);

                sliderTrack.style.transition = 'transform 0.5s ease';

                // Determine if we should move to next/prev slide
                const visibleCards = getVisibleCards();
                const maxIndex = filteredProducts.length - visibleCards;

                if (Math.abs(distance) > 50 || velocity > 0.3) {
                    if (distance > 0 && currentIndex > 0) {
                        currentIndex--;
                    } else if (distance < 0 && currentIndex < maxIndex) {
                        currentIndex++;
                    }
                }

                updateSliderPosition();
                updateButtons();
                startAutoScroll();
            });

            sliderContainer.addEventListener('mouseleave', () => {
                if (isDragging) {
                    isDragging = false;
                    sliderContainer.style.cursor = 'grab';
                    sliderTrack.style.transition = 'transform 0.5s ease';
                    updateSliderPosition();
                    updateButtons();
                    startAutoScroll();
                }
            });

            // Window resize handler
            window.addEventListener('resize', () => {
                updateSliderPosition();
                updateButtons();
            });

            // Initialize
            applyFilters();
            updateButtons();
            startAutoScroll();
            } // end initSliderFilters

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initSliderFilters);
            } else {
                initSliderFilters();
            }
        })();
        </script>
<script type='application/javascript' >
				const lazyloadRunObserver = () => {
					const lazyloadBackgrounds = document.querySelectorAll( `.e-con.e-parent:not(.e-lazyloaded)` );
					const lazyloadBackgroundObserver = new IntersectionObserver( ( entries ) => {
						entries.forEach( ( entry ) => {
							if ( entry.isIntersecting ) {
								let lazyloadBackground = entry.target;
								if( lazyloadBackground ) {
									lazyloadBackground.classList.add( 'e-lazyloaded' );
								}
								lazyloadBackgroundObserver.unobserve( entry.target );
							}
						});
					}, { rootMargin: '200px 0px 200px 0px' } );
					lazyloadBackgrounds.forEach( ( lazyloadBackground ) => {
						lazyloadBackgroundObserver.observe( lazyloadBackground );
					} );
				};
				const events = [
					'DOMContentLoaded',
					'elementor/lazyload/observe',
				];
				events.forEach( ( event ) => {
					document.addEventListener( event, lazyloadRunObserver );
				} );
			</script>
