					<style type="text/css" id="wp-custom-css">
			/* Format address on card properly */
.address__country-short,
.address__country {
	display: none;
}

.address__postcode, .address__city {
	display: inline;
}

/* Change Blog Post – Featured Area Content Color */ .single:not(.single-job_listing) .entry-title, .single:not(.single-job_listing) .entry-subtitle, .single:not(.single-job_listing) .entry-meta a { color: white !important;	} 

/* Change Blog Post – Featured Image Opacity */ .single:not(.single-job_listing) .entry-featured { opacity: 0.7; }


/* Change Blog Post – Featured Image Background */ .single:not(.single-job_listing) .entry-header { background: black;	}

.post > .entry-header {
	padding: 9em 0 9em 0 !important;
}

/* Fjern linjeskift */

body {
	hyphens: manual !important;
	word-break: keep-all !important;
}

/* Responsive video */ 
.iframe-16-9 {
	position: relative;
	padding-bottom: 56.25%;
/* 16:9 */
/*padding-top: 25px;*/
	height: 0;
}

.iframe-16-9 iframe {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
}

.iframe-4-3 {
	position: relative;
	padding-bottom: 75%;
/* 4:3 */
/*padding-top: 25px;*/
	height: 0;
}

.iframe-4-3 iframe {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
}

.iframe-1-1 {
	position: relative;
	padding-bottom: 100%;
/* 1:1 */
/*padding-top: 25px;*/
	height: 0;
}

.iframe-1-1 iframe {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
}

.posted-on, .card__links:before {
	display: none;
}



@media only screen and (max-width: 768px) {
  body {
    font-size: 16px;
  }
}

@media only screen and (max-width: 1099px) {
  .page-header {
    padding: 5rem;
  }
	h1.page-title {
		margin-bottom: 15px;
		font-size: 1.5em !important;
  }
}

@media only screen and (min-width: 1100px) {
  .page-header {
    padding: 7rem;
  }
	h1.page-title {
		margin-bottom: 25px;
  }
}

.comment-content, #cookie-notice {
	font-size: 16px !important;
}

.elementor-text-editor a, .elementor-widget-container a {
	color: #DD3333; 
}

/* Remove results text from map (beside 'reset' button) */
.showing_jobs .results span {
	display: inline;
}

.showing_jobs span {
	display: none;
}

/* Card border width */
.card--listing.is--featured:after,
.card--listing.card--widget.is--featured:after,
.card:after {
	border-width: 2px;
}

/* Votingbird */
.vb-voting-title {
	font-family: Pacifico, serif !important;
	font-size: 2rem;
	color: #005860;
}

._vb table tr {
	display: table-row !important;
}

.widget--footer {
	padding: 0;
	margin: 0;
	max-width: 2000px;
}



/* List fixes */



/*ul {
display: block;
    list-style-type: disc;
    margin-left: 0px;
    margin-right: 0px;
    padding: 0 0 0 40px;

}

ul li {
	display: list-item;
}

*/


/* Shop fixes */
@media only screen and (min-width: 900px) {
	.page-header:not(.has-featured-image) {
    padding: 3.75rem;}
}

.wc-cart-shipping-notice {
	display: none;
}

.voucher-fields .form-row {
	display: none;
}

.voucher-image-options {
	display: none;
}

.cart {
	display:block !important;
}

.quantity {
	width: 45%;
}

.single_add_to_cart_button {
		width: 45%;
		float: right;
}

td.value select {
	position: relative !important;
}

.entry-content table:not(.cart-totals):not(.ui-datepicker-calendar), #job-manager-job-dashboard table {
	border-radius: 3px !important;
}

.woocommerce div.product.elementor form.cart table.variations td {
	padding: 15px 20px !important;
}

/* Cookie consent*/
#cn-notice-text p {
	margin-top: 10px;
	margin-bottom: 10px;
}

.cn-button {
	background: #dd3333 !important;
	border: 2px solid white !important;
}

.cn-button:hover {
	color: #dd3333 !important;
	background: white !important;
	border: 2px solid white !important;
	box-shadow: none;
}

.woocommerce-variation.single_variation {
	margin-bottom: 12px !important;
}

.ee-post__metas__list {
	list-style: none !important;
}

.woocommerce div.product.elementor form.cart table.variations td.label {
	width: 50% !important;
}

.woocommerce div.product.elementor form.cart table.variations td {
    padding: 15px 0px !important;
}

.woocommerce div.product.elementor form.cart table.variations td.value select {
    border: solid 2px #eeeafa !important;
    position: absolute;
    background: transparent;
    top: 0;
    padding: 0;
    width: 200px;
}

table.table--checkout div.card__content{
	padding-left: 0 !important;
}

/* OpdagDanmark */
.odk-list li {
	display: list-item;
	position: relative;
    padding: 0.25em 0;
}

.odk-list-inset ul {
 margin-bottom: 20px !important;   
}

.odk-list-inset li {
    display: list-item !important;
	position: relative !important;
    padding: 0.25em 0em !important;
    margin: 0.25em 40px !important;
}

/* hide tags filter på kort */
.select-tags {
	display: none;
}

