            padding: 12px 16px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 15px;
            font-family: inherit;
            transition: all 0.2s;
            background: white;
        }

        .products-slider-municipality-select:focus {
            outline: none;
            border-color: #dd3333;
            box-shadow: 0 0 0 3px rgba(221,51,51, 0.1);
        }

        .products-slider-nav-wrapper {
            position: relative;
        }

        .products-slider-container {
            position: relative;
            overflow: hidden;
            cursor: grab;
            user-select: none;
            margin: 0 60px;
        }

        .products-slider-container:active {
            cursor: grabbing;
        }

        .products-slider-track {
            display: flex;
            gap: 30px;
            transition: transform 0.5s ease;
        }

        .products-slider-track .product-card {
            flex: 0 0 calc(25% - 22.5px);
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
            transition: box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            min-height: 380px;
            max-height: 420px;
        }

        .products-slider-track .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.16);
        }

        .slider-nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 48px;
            height: 48px;
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            color: #dd3333;
        }

        .slider-nav-btn svg {
            width: 40px;
            height: 40px;
            display: block;
        }

        .slider-nav-btn svg path {
            fill: #dd3333;
        }

        .slider-nav-btn:hover:not(:disabled) {
            transform: translateY(-50%) scale(1.15);
        }

        .slider-nav-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .slider-nav-btn.prev {
            left: 4px;
        }

        .slider-nav-btn.next {
            right: 4px;
        }

        .no-products-msg-slider {
            text-align: center;
            padding: 100px 40px;
            width: 100%;
        }

        .no-products-icon-slider {
            font-size: 80px;
            margin-bottom: 24px;
            opacity: 0.5;
        }

        .no-products-msg-slider h3 {
            font-size: 28px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 12px;
        }

        .no-products-msg-slider p {
            font-size: 18px;
            color: #7f8c8d;
        }

        /* Products slider uses same card styling as magazine layout */
        .products-slider-track .product-card .event-card-body {
            display: flex;
            flex-direction: column;
        }

        .products-slider-track .product-card .event-card-actions {
            margin-top: auto;
        }

        @media (max-width: 1400px) {
            .products-slider-track .product-card {
                flex: 0 0 calc(33.333% - 20px);
            }
        }

        @media (max-width: 1024px) {
            .products-slider-track .product-card {
                flex: 0 0 calc(50% - 15px);
            }
        }

        @media (max-width: 768px) {
            .products-slider-container {
                margin: 0 16px;
            }

            .products-slider-track {
                gap: 15px;
            }

            .products-slider-track .product-card {
                flex: 0 0 calc(50% - 8px);
            }

            .slider-nav-btn {
                width: 36px;
                height: 36px;
                top: 110px;
                transform: translateY(-50%);
            }

            .slider-nav-btn svg {
                width: 32px;
                height: 32px;
            }

            .slider-nav-btn.prev {
                left: 0;
            }

            .slider-nav-btn.next {
                right: 0;
            }

            .products-slider-filters {
                padding: 16px;
                gap: 12px;
            }

            .products-slider-filter-group {
                min-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .products-slider-track .product-card {
                flex: 0 0 100%;
            }
        }
